{{- /* Atom 1.0 (RFC 4287) at /feed.xml; mediatype application/atom+xml in config. */ -}}
{{- $entries := first 15 site.RegularPages.ByDate.Reverse -}}
{{- $feedURL := "feed.xml" | absURL -}}
{{- $feedUpdated := now -}}
{{- with index $entries 0 -}}
	{{- $feedUpdated = .Lastmod | default .Date -}}
{{- end -}}
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ or site.Language.LanguageCode site.Language.Lang }}">
  <title>{{ site.Title | html }}</title>
  <icon>{{ "touch-icon-iphone-retinahd.png" | absURL }}</icon>
  <rights>Copyright (c) 2014–{{ now.Format "2006" }} {{ site.Params.author | html }}. All rights reserved.</rights>
  <link rel="self" type="application/atom+xml" href="{{ $feedURL }}"/>
  <link rel="alternate" type="text/html" href="{{ site.Home.Permalink }}"/>
  <updated>{{ $feedUpdated.Format "2006-01-02T15:04:05-07:00" }}</updated>
  <author>
    <name>{{ site.Params.author | html }}</name>
  </author>
  <id>{{ $feedURL }}</id>
  <generator uri="https://gohugo.io/" version="{{ hugo.Version }}">Hugo</generator>

  {{- range $entries }}
  <entry xml:base="{{ .Permalink }}">
    <title>{{ .Title | html }}</title>
    <link rel="alternate" type="text/html" href="{{ .Permalink }}"/>
    <id>{{ .Permalink }}</id>
    <published>{{ .Date.Format "2006-01-02T15:04:05-07:00" }}</published>
    <updated>{{ if .Lastmod.After .Date }}{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" }}{{ else }}{{ .Date.Format "2006-01-02T15:04:05-07:00" }}{{ end }}</updated>
    {{- with .Params.series }}
    <category term="{{ . | html }}"/>
    {{- end }}
    {{- if .Params.tags }}{{ range .Params.tags }}
    <category term="{{ . | html }}"/>
    {{- end }}{{ end }}
    <content type="html">{{ .Summary | html }}</content>
  </entry>
  {{- end }}
</feed>
